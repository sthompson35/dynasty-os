# ============================================================
# Dynasty OS — Environment Variable Template
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
APP_ENV=development        # development | staging | production
DEBUG=false
LOG_LEVEL=INFO

# ------------------------------------------------------------
# Database (required — use PostgreSQL in staging/production)
# ------------------------------------------------------------
DATABASE_URL=******host:5432/dynasty_os
# For local SQLite dev only:
# DATABASE_URL=sqlite:///./test.db

# ------------------------------------------------------------
# Redis / Celery
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ------------------------------------------------------------
# Slack Integration (required in production)
# ------------------------------------------------------------
SLACK_SIGNING_SECRET=your-slack-signing-secret-here
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_VERIFICATION_TOKEN=
SLACK_APP_ID=

# ------------------------------------------------------------
# AI Providers
# ------------------------------------------------------------
ABACUS_API_KEY=your-abacus-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
LM_STUDIO_BASE_URL=http://host.docker.internal:1234/v1

# ------------------------------------------------------------
# Storage (S3-compatible / MinIO)
# ------------------------------------------------------------
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=slack-ai-outputs

# MinIO (local dev only)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ------------------------------------------------------------
# Supabase (Workstream 2 — required when using Supabase backend)
# ------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here
SUPABASE_DB_SCHEMA=public          # optional, defaults to "public"

# ------------------------------------------------------------
# Optional monitoring
# ------------------------------------------------------------
FLOWER_BASIC_AUTH=admin:admin
