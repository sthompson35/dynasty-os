SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres
DATABASE_URL_DOCKER=postgresql://postgres:postgres@postgres:5432/postgres
REDIS_URL_DOCKER=redis://redis:6379/0
BLENDER_PATH=C:\Program Files\Blender Foundation\Blender 4.2\blender.exe
BLENDER_PATH_DOCKER=blender
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_API_BASE_URL_DOCKER=http://api:8000
RAILWAY_BACKEND_PUBLIC_URL=
RAILWAY_FRONTEND_PUBLIC_URL=
N8N_DYNASTY_API_URL=http://localhost:8010
N8N_DYNASTY_API_URL_DOCKER=http://api:8000

# ngrok — exposes the Dynasty API to n8n cloud
# Get your auth token at: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your-ngrok-authtoken-here
# Your static ngrok domain (skip API lookup if set). Leave blank to auto-detect.
NGROK_DOMAIN=your-subdomain.ngrok-free.dev

# n8n cloud API — auto-syncs ngrok URL into workflow and activates it
# Get your API key at: https://ultimate-dynasty-os.app.n8n.cloud/settings/api
N8N_API_KEY=your-n8n-api-key-here
N8N_CLOUD_URL=https://ultimate-dynasty-os.app.n8n.cloud
N8N_WORKFLOW_ID=OEGkyufLk21eS6lz
# V3 workflow ID — set after importing n8n/dynasty-os-v3-workflow.json into n8n
N8N_WORKFLOW_ID_V3=

# Service-to-service automation auth for n8n -> PropertyOS execution routes.
# Send this value as x-automation-secret. The automation user can be resolved
# by id or email; email falls back to NOTIFICATION_EMAIL when omitted.
AUTOMATION_SECRET=change-me-to-a-long-random-secret
AUTOMATION_USER_ID=
AUTOMATION_USER_EMAIL=

# Owner contact — used by V3 SMS alerts (Twilio)
DYNASTY_OWNER_PHONE=+1xxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
CORS_ALLOW_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:3005,http://localhost:3005
LOG_LEVEL=INFO
NEXTAUTH_URL=http://localhost:3005
NEXTAUTH_SECRET=change-me-in-production
NEXT_PUBLIC_SITE_URL=http://localhost:3005
LLMSTUDIO_BASE_URL=http://127.0.0.1:1234
LLMSTUDIO_BASE_URL_DOCKER=http://host.docker.internal:1234
LLMSTUDIO_DEFAULT_MODEL=qwen3-coder:30b-a3b-instruct-q4_K_M
LLMSTUDIO_API_KEY=lm-studio
LLMSTUDIO_TIMEOUT_SECONDS=5
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5433
REDIS_PORT=6379
API_PORT=8010
FRONTEND_PORT=3005
N8N_PORT=5678
N8N_WEBHOOK_URL=http://localhost:5678
GENERIC_TIMEZONE=UTC
AI_WORKER_INTERVAL_SECONDS=60
BLENDER_WORKER_INTERVAL_SECONDS=60
BLENDER_RUN_ON_START=false
BLENDER_TRIGGER_FILE=storage/blender_jobs/run.flag
CODEPLOIT_ENABLED=true

