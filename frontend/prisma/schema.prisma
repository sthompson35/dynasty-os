generator client {
    provider        = "prisma-client-js"
    binaryTargets   = ["native"]
    previewFeatures = ["multiSchema"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
    schemas  = ["dynasty"]
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String     @default("INVESTOR")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  accounts             Account[]
  sessions             Session[]
  properties           Property[]
  ownerIntelligenceArtifacts OwnerIntelligenceArtifact[]
  skipTraceExportQueue SkipTraceExportQueue[]
  ownershipResearchTasks OwnershipResearchTask[]
  dealScores           DealScore[]
  leadActionQueue      LeadActionQueue[]
  campaignBatches      CampaignBatch[]
  campaignItems        CampaignItem[]
  shares               DealShare[]
  documents            PropertyDocument[]
  contacts             Contact[]
  images               PropertyImage[]
  leads                Lead[]
  deals                Deal[]
  leadIntakeArtifacts  LeadIntakeArtifact[]
  sellerConversations  SellerConversation[]
  sellerFollowups      SellerFollowup[]
  sellerOffers         SellerOffer[]
  sellerNegotiations   SellerNegotiation[]
  buyerProfiles        BuyerProfile[]
  buyerCriteria        BuyerCriteria[]
  buyerMatches         BuyerMatch[]
  dispositionPackages  DispositionPackage[]
  assignmentPipeline   AssignmentPipeline[]
  closingTracker       ClosingTracker[]
  investors            Investor[]
  capitalTransactions  CapitalTransaction[]
  projects             Project[]
  buyers               Buyer[]
  dispositions         Disposition[]
  propertyActivities   PropertyActivity[]
  dealOutcomes         DealOutcome[]

  @@index([email])
  @@schema("dynasty")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@schema("dynasty")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@schema("dynasty")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@schema("dynasty")
}

model Property {
  id             String   @id @default(cuid())
  userId         String
  address        String
  city           String
  state          String
  zip            String?
  propertyType   String   @default("single-family")
  bedrooms       Int?
  bathrooms      Float?
  sqft           Int?
  lotSize        Float?
  yearBuilt      Int?
  purchasePrice  Decimal? @db.Decimal(14, 2)
  currentValue   Decimal? @db.Decimal(14, 2)
  status         String   @default("prospect")
  photoUrl       String?  @db.Text
  notes          String?  @db.Text
  virtualTourUrl String?  @db.Text
  arv            Decimal? @db.Decimal(14, 2)
  repairCosts    Decimal? @db.Decimal(14, 2)
  holdingCosts   Decimal? @db.Decimal(14, 2)
  closingCosts   Decimal? @db.Decimal(14, 2)
  latitude       Float?
  longitude      Float?
  censusTract    String?
  censusGeoid    String?
  floodZone      String?
  floodZoneSource String?
  zoningDistrict String?
  zoningSource   String?
  gisEnrichedAt  DateTime?
  femaDisasterCount    Int?
  femaLastDisasterDate DateTime?
  femaLastDisasterType String?
  femaDisasterSource   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rehabItems     RehabItem[]
  shares         DealShare[]
  documents      PropertyDocument[]
  contactLinks   PropertyContact[]
  ownerIntelligenceArtifacts OwnerIntelligenceArtifact[]
  skipTraceExportQueue SkipTraceExportQueue[]
  ownershipResearchTasks OwnershipResearchTask[]
  draws          Draw[]
  images         PropertyImage[]
  dealScores     DealScore[]
  leadActionQueue LeadActionQueue[]
  campaignItems  CampaignItem[]
  leadIntakeArtifacts LeadIntakeArtifact[]
  sellerConversations SellerConversation[]
  sellerFollowups SellerFollowup[]
  sellerOffers   SellerOffer[]
  sellerNegotiations SellerNegotiation[]
  buyerMatches   BuyerMatch[]
  dispositionPackages DispositionPackage[]
  activities     PropertyActivity[]
  dealOutcomes   DealOutcome[]

  @@index([userId])
  @@index([userId, status])
  @@index([userId, propertyType])
  @@index([userId, updatedAt])
  @@schema("dynasty")
}

model OwnerIntelligenceArtifact {
  id                String   @id @default(cuid())
  propertyId        String   @map("property_id")
  userId            String   @map("user_id")
  ownerName         String?  @map("owner_name")
  mailingAddress    String?  @map("mailing_address") @db.Text
  ownerType         String   @default("UNKNOWN") @map("owner_type")
  absenteeOwner     Boolean  @default(false) @map("absentee_owner")
  yearsOwned        Float?   @map("years_owned")
  equityEstimate    Decimal? @map("equity_estimate") @db.Decimal(14, 2)
  vacancyIndicator  Boolean  @default(false) @map("vacancy_indicator")
  contactConfidence Int      @default(0) @map("contact_confidence")
  phones            Json     @default("[]")
  emails            Json     @default("[]")
  source            String   @default("PROPERTY_NOTES")
  evidence          Json     @default("{}")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  property          Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skipTraceExportQueue SkipTraceExportQueue[]

  @@unique([userId, propertyId])
  @@index([propertyId])
  @@index([userId])
  @@index([userId, absenteeOwner])
  @@index([userId, vacancyIndicator])
  @@index([userId, contactConfidence])
  @@map("owner_intelligence_artifacts")
  @@schema("dynasty")
}

model SkipTraceExportQueue {
  id                 String                     @id @default(cuid())
  propertyId         String                     @map("property_id")
  ownerArtifactId    String                     @map("owner_artifact_id")
  userId             String                     @map("user_id")
  propertyAddress    String                     @map("property_address") @db.Text
  mailingAddress     String?                    @map("mailing_address") @db.Text
  absenteeOwner      Boolean                    @default(false) @map("absentee_owner")
  vacancySignal      Boolean                    @default(false) @map("vacancy_signal")
  equitySignal       Decimal?                   @map("equity_signal") @db.Decimal(14, 2)
  priority           Int
  recommendedChannel String                     @map("recommended_channel")
  status             String                     @default("READY")
  evidence           Json                       @default("{}")
  createdAt          DateTime                   @default(now()) @map("created_at")
  updatedAt          DateTime                   @updatedAt @map("updated_at")
  property           Property                   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  ownerArtifact      OwnerIntelligenceArtifact  @relation(fields: [ownerArtifactId], references: [id], onDelete: Cascade)
  user               User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  ownershipResearchTasks OwnershipResearchTask[]

  @@unique([userId, propertyId])
  @@index([propertyId])
  @@index([ownerArtifactId])
  @@index([userId])
  @@index([userId, recommendedChannel])
  @@index([userId, status])
  @@index([userId, priority])
  @@map("skip_trace_export_queue")
  @@schema("dynasty")
}

model OwnershipResearchTask {
  id                String               @id @default(cuid())
  propertyId        String               @map("property_id")
  skipTraceQueueId  String               @map("skip_trace_queue_id")
  userId            String               @map("user_id")
  propertyAddress   String               @map("property_address") @db.Text
  mailingAddress    String?              @map("mailing_address") @db.Text
  county            String?
  sourcePriority    Int                  @default(50) @map("source_priority")
  researchStatus    String               @default("READY") @map("research_status")
  researchReason    String               @map("research_reason") @db.Text
  recommendedSource String               @map("recommended_source")
  recoveredOwnerName String?             @map("recovered_owner_name")
  confidence        Int?
  sourceUrl         String?              @map("source_url") @db.Text
  researchNotes     String?              @map("research_notes") @db.Text
  completedAt       DateTime?            @map("completed_at")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")
  property          Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  skipTraceQueue    SkipTraceExportQueue @relation(fields: [skipTraceQueueId], references: [id], onDelete: Cascade)
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([propertyId])
  @@index([skipTraceQueueId])
  @@index([userId])
  @@index([userId, county])
  @@index([userId, researchStatus])
  @@index([userId, sourcePriority])
  @@map("ownership_research_tasks")
  @@schema("dynasty")
}

model DealScore {
  id            String   @id @default(cuid())
  propertyId    String   @map("property_id")
  userId        String   @map("user_id")
  dealScore     Int      @map("deal_score")
  riskScore     Int      @map("risk_score")
  arvConfidence Int      @map("arv_confidence")
  capitalScore  Int      @map("capital_score")
  strategy      String
  decision      String
  scoreBucket   String   @map("score_bucket")
  reasons       Json     @default("[]")
  inputs        Json     @default("{}")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  property      Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadActionQueue LeadActionQueue[]
  dealOutcomes  DealOutcome[]

  @@unique([userId, propertyId])
  @@index([propertyId])
  @@index([userId])
  @@index([userId, decision])
  @@index([userId, scoreBucket])
  @@index([userId, dealScore])
  @@map("deal_scores")
  @@schema("dynasty")
}

// Closes the prediction-vs-reality loop on the real, DealScore-scored
// portfolio (not the disconnected manual Deal model - see project memory
// on why this anchors to Property/DealScore instead). One row per property;
// predicted fields are a frozen snapshot taken at record time, not a live
// join to DealScore, since DealScore is upserted per property and would
// otherwise silently drift out from under a recorded outcome.
model DealOutcome {
  id                String    @id @default(cuid())
  userId            String
  propertyId        String
  dealScoreId       String?

  status            String    @default("closed") // closed | fell_through
  closeDate         DateTime?

  predictedDecision String?
  predictedScore    Int?
  predictedStrategy String?
  projectedPurchase Decimal?  @db.Decimal(14, 2)
  projectedRehab    Decimal?  @db.Decimal(14, 2)
  projectedExit     Decimal?  @db.Decimal(14, 2)

  actualStrategy    String?
  actualPurchase    Decimal?  @db.Decimal(14, 2)
  actualRehab       Decimal?  @db.Decimal(14, 2)
  actualExit        Decimal?  @db.Decimal(14, 2)
  holdMonths        Decimal?  @db.Decimal(6, 2)

  // Derived from the actuals above at save time (see lib/deal-outcome.ts)
  netProfit         Decimal?  @db.Decimal(14, 2)
  roi               Decimal?  @db.Decimal(8, 4)

  decisionSource    String?
  postMortemNote    String?   @db.Text

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  property          Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  dealScoreRef      DealScore? @relation(fields: [dealScoreId], references: [id], onDelete: SetNull)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([userId, status])
  @@map("deal_outcomes")
  @@schema("dynasty")
}

model LeadActionQueue {
  id             String    @id @default(cuid())
  propertyId     String    @map("property_id")
  dealScoreId    String    @map("deal_score_id")
  userId         String    @map("user_id")
  actionType     String    @map("action_type")
  priority       Int
  status         String    @default("OPEN")
  assignedTo     String?   @map("assigned_to")
  nextActionDate DateTime? @map("next_action_date")
  reason         String    @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  property       Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  dealScore      DealScore @relation(fields: [dealScoreId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignItems  CampaignItem[]

  @@unique([userId, propertyId])
  @@index([propertyId])
  @@index([dealScoreId])
  @@index([userId])
  @@index([userId, actionType])
  @@index([userId, status])
  @@index([userId, priority])
  @@index([userId, nextActionDate])
  @@map("lead_action_queue")
  @@schema("dynasty")
}

model CampaignBatch {
  id            String         @id @default(cuid())
  userId        String         @map("user_id")
  name          String
  campaignType  String         @map("campaign_type")
  status        String         @default("DRAFT")
  scheduledDate DateTime?      @map("scheduled_date")
  totalItems    Int            @default(0) @map("total_items")
  completedItems Int           @default(0) @map("completed_items")
  notes         String?        @db.Text
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items         CampaignItem[]

  @@index([userId])
  @@index([userId, campaignType])
  @@index([userId, status])
  @@index([userId, scheduledDate])
  @@map("campaign_batches")
  @@schema("dynasty")
}

model CampaignItem {
  id            String          @id @default(cuid())
  batchId       String          @map("batch_id")
  queueItemId   String          @map("queue_item_id")
  propertyId    String          @map("property_id")
  userId        String          @map("user_id")
  campaignType  String          @map("campaign_type")
  status        String          @default("READY")
  priority      Int
  artifact      Json            @default("{}")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  batch         CampaignBatch   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  queueItem     LeadActionQueue @relation(fields: [queueItemId], references: [id], onDelete: Cascade)
  property      Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([batchId, queueItemId])
  @@index([batchId])
  @@index([queueItemId])
  @@index([propertyId])
  @@index([userId])
  @@index([userId, campaignType])
  @@index([userId, status])
  @@map("campaign_items")
  @@schema("dynasty")
}

model RehabItem {
  id          String   @id @default(cuid())
  propertyId  String
  room        String   @default("General")
  category    String   @default("Materials")
  description String
  quantity    Float    @default(1)
  unitCost    Decimal  @default(0) @db.Decimal(14, 2)
  status      String   @default("planned")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@schema("dynasty")
}

model Draw {
  id            String    @id @default(cuid())
  propertyId    String
  name          String
  description   String?   @db.Text
  amount        Decimal   @default(0) @db.Decimal(14, 2)
  status        String    @default("pending")
  sortOrder     Int       @default(0)
  scheduledDate DateTime?
  fundedDate    DateTime?
  lender        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  property      Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@schema("dynasty")
}

model DealShare {
  id             String   @id @default(cuid())
  propertyId     String
  userId         String
  token          String   @unique
  title          String?
  message        String?  @db.Text
  preparedBy     String?
  contactEmail   String?
  showFinancials Boolean  @default(true)
  showRehab      Boolean  @default(true)
  isActive       Boolean  @default(true)
  viewCount      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  property       Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([userId])
  @@index([token])
  @@schema("dynasty")
}

model PropertyDocument {
  id               String   @id @default(cuid())
  propertyId       String
  userId           String
  fileName         String
  cloudStoragePath String   @db.Text
  contentType      String   @default("application/octet-stream")
  fileSize         Int      @default(0)
  category         String   @default("other")
  isPublic         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  property         Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([userId])
  @@index([propertyId, category])
  @@schema("dynasty")
}

model Contact {
  id        String   @id @default(cuid())
  userId    String
  name      String
  role      String   @default("other")
  email     String?
  phone     String?
  company   String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  links     PropertyContact[]

  @@index([userId])
  @@index([userId, role])
  @@schema("dynasty")
}

model PropertyImage {
  id               String   @id @default(cuid())
  propertyId       String
  userId           String
  url              String   @db.Text
  cloudStoragePath String   @db.Text
  caption          String?
  isPrimary        Boolean  @default(false)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  property         Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([userId])
  @@index([propertyId, sortOrder])
  @@schema("dynasty")
}

model PropertyContact {
  id                   String   @id @default(cuid())
  propertyId           String
  contactId            String
  userId               String
  roleOnDeal           String?
  relationshipType     String?
  dealResponsibility   String?  @db.Text
  status               String   @default("active")
  nextActionDate       DateTime?
  lastContacted        DateTime?
  documentsNeeded      String?  @db.Text
  paymentOwed          Decimal? @db.Decimal(14, 2)
  receivesUpdates      Boolean  @default(false)
  communicationHistory String?  @db.Text
  createdAt            DateTime @default(now())
  property             Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  contact              Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([propertyId, contactId])
  @@index([propertyId])
  @@index([contactId])
  @@index([userId])
  @@index([propertyId, status])
  @@index([propertyId, nextActionDate])
  @@schema("dynasty")
}

// ─── LEAD ENGINE ─────────────────────────────────────────────────────────────

model Lead {
  id             String    @id @default(cuid())
  userId         String
  leadType       String    @default("seller")
  source         String    @default("direct")
  score          Int       @default(0)
  status         String    @default("new")
  stage          String    @default("intake")
  firstName      String?
  lastName       String?
  email          String?
  phone          String?
  address        String?
  city           String?
  state          String?
  zip            String?
  motivation     String?
  equity         Decimal?  @db.Decimal(14, 2)
  askingPrice    Decimal?  @db.Decimal(14, 2)
  notes          String?   @db.Text
  nextAction     String?
  nextActionDate DateTime?
  owner          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, leadType])
  @@index([userId, status])
  @@schema("dynasty")
}

// ─── DEAL ENGINE ──────────────────────────────────────────────────────────────

model Deal {
  id               String    @id @default(cuid())
  userId           String
  propertyId       String?
  address          String
  city             String
  state            String
  zip              String?
  exitStrategy     String    @default("wholesale")
  status           String    @default("intake")
  purchasePrice    Decimal?  @db.Decimal(14, 2)
  arv              Decimal?  @db.Decimal(14, 2)
  repairCosts      Decimal?  @db.Decimal(14, 2)
  holdingCosts     Decimal?  @db.Decimal(14, 2)
  closingCosts     Decimal?  @db.Decimal(14, 2)
  mao              Decimal?  @db.Decimal(14, 2)
  wholesaleFee     Decimal?  @db.Decimal(14, 2)
  flipProfit       Decimal?  @db.Decimal(14, 2)
  rentalEquity     Decimal?  @db.Decimal(14, 2)
  monthlyCashFlow  Decimal?  @db.Decimal(14, 2)
  roi              Decimal?  @db.Decimal(8, 4)
  riskScore        Int       @default(0)
  decision         String    @default("pending")
  capitalRequired  Decimal?  @db.Decimal(14, 2)
  capitalAllocated Decimal?  @db.Decimal(14, 2)
  notes            String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dispositions     Disposition[]
  leadIntakeArtifacts LeadIntakeArtifact[]
  sellerOffers     SellerOffer[]
  buyerMatches     BuyerMatch[]
  dispositionPackages DispositionPackage[]
  assignmentPipeline AssignmentPipeline[]
  closingTracker   ClosingTracker[]

  @@index([userId])
  @@index([userId, status])
  @@index([userId, decision])
  @@schema("dynasty")
}

model LeadIntakeArtifact {
  id              String    @id @default(cuid())
  propertyId      String    @map("property_id")
  userId          String    @map("user_id")
  dealId          String?   @map("deal_id")
  ownerName       String?   @map("owner_name")
  contactName     String?   @map("contact_name")
  phone           String?
  email           String?
  contactDate     DateTime? @map("contact_date")
  leadSource      String    @default("CALL_CAMPAIGN") @map("lead_source")
  motivationScore Int       @default(0) @map("motivation_score")
  askingPrice     Decimal?  @map("asking_price") @db.Decimal(14, 2)
  occupancyStatus String?   @map("occupancy_status")
  timeline        String?
  painPoints      String[]  @default([]) @map("pain_points")
  notes           String?   @db.Text
  status          String    @default("NEW")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal            Deal?     @relation(fields: [dealId], references: [id], onDelete: SetNull)
  conversations   SellerConversation[]

  @@index([propertyId])
  @@index([userId])
  @@index([dealId])
  @@index([userId, status])
  @@index([userId, motivationScore])
  @@index([userId, contactDate])
  @@map("lead_intake_artifacts")
  @@schema("dynasty")
}

// ─── SELLER CRM (CONVERSATIONS → FOLLOW-UPS → OFFERS → NEGOTIATIONS) ─────────

model SellerConversation {
  id                String   @id @default(cuid())
  leadIntakeId      String   @map("lead_intake_id")
  propertyId        String   @map("property_id")
  userId            String   @map("user_id")
  conversationType  String   @default("CALL") @map("conversation_type")
  summary           String   @db.Text
  objections        String[] @default([])
  motivationChanges String?  @map("motivation_changes") @db.Text
  nextStep          String?  @map("next_step") @db.Text
  recordedAt        DateTime @default(now()) @map("recorded_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  leadIntake        LeadIntakeArtifact @relation(fields: [leadIntakeId], references: [id], onDelete: Cascade)
  property          Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  followups         SellerFollowup[]

  @@index([leadIntakeId])
  @@index([propertyId])
  @@index([userId])
  @@index([userId, conversationType])
  @@index([userId, recordedAt])
  @@map("seller_conversations")
  @@schema("dynasty")
}

model SellerFollowup {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  propertyId     String   @map("property_id")
  userId         String   @map("user_id")
  followupDate   DateTime @map("followup_date")
  followupType   String   @default("CALL") @map("followup_type")
  assignedTo     String?  @map("assigned_to")
  status         String   @default("OPEN")
  notes          String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  conversation   SellerConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  property       Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([propertyId])
  @@index([userId])
  @@index([userId, status])
  @@index([userId, followupDate])
  @@map("seller_followups")
  @@schema("dynasty")
}

model SellerOffer {
  id             String    @id @default(cuid())
  propertyId     String    @map("property_id")
  dealId         String    @map("deal_id")
  userId         String    @map("user_id")
  offerAmount    Decimal   @map("offer_amount") @db.Decimal(14, 2)
  offerType      String    @default("CASH") @map("offer_type")
  sentDate       DateTime? @map("sent_date")
  expirationDate DateTime? @map("expiration_date")
  status         String    @default("DRAFT")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  property       Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  deal           Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  negotiations   SellerNegotiation[]

  @@index([propertyId])
  @@index([dealId])
  @@index([userId])
  @@index([userId, status])
  @@index([userId, sentDate])
  @@map("seller_offers")
  @@schema("dynasty")
}

model SellerNegotiation {
  id               String   @id @default(cuid())
  offerId          String   @map("offer_id")
  propertyId       String   @map("property_id")
  userId           String   @map("user_id")
  counterAmount    Decimal? @map("counter_amount") @db.Decimal(14, 2)
  sellerResponse   String?  @map("seller_response") @db.Text
  negotiationStage String   @default("OPEN") @map("negotiation_stage")
  resolution       String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  offer            SellerOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  property         Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([offerId])
  @@index([propertyId])
  @@index([userId])
  @@index([userId, negotiationStage])
  @@map("seller_negotiations")
  @@schema("dynasty")
}

// ─── CAPITAL ENGINE ───────────────────────────────────────────────────────────

model Investor {
  id               String    @id @default(cuid())
  userId           String
  name             String
  entity           String?
  email            String?
  phone            String?
  status           String    @default("prospect")
  availableCapital Decimal?  @db.Decimal(14, 2)
  committedCapital Decimal?  @db.Decimal(14, 2)
  investedCapital  Decimal?  @db.Decimal(14, 2)
  preferredReturn  Decimal?  @db.Decimal(5, 4)
  investmentType   String    @default("private_loan")
  markets          String?
  notes            String?   @db.Text
  // Where this investor relationship originated (REIA, LinkedIn, BiggerPockets,
  // referral, website, event, etc.) - lets qualification/prospecting scoring
  // reward a known-good channel the way it already rewards real capital signals.
  evidenceSource   String?
  // Snapshot of the qualification score/reasons as of the last time it was
  // computed (see lib/investor-qualification-change.ts) - lets a later read
  // detect a material improvement without a full event-log table.
  lastQualificationScore   Int?
  lastQualificationReasons Json?
  lastQualificationAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  distributions    InvestorDistribution[]
  transactions     CapitalTransaction[]

  @@index([userId])
  @@index([userId, status])
  @@schema("dynasty")
}

model CapitalTransaction {
  id         String    @id @default(cuid())
  userId     String
  investorId String?
  dealId     String?
  type       String
  amount     Decimal   @db.Decimal(14, 2)
  date       DateTime  @default(now())
  status     String    @default("pending")
  notes      String?   @db.Text
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  investor   Investor? @relation(fields: [investorId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, type])
  @@index([investorId])
  @@schema("dynasty")
}

// ─── OPERATIONS ENGINE ────────────────────────────────────────────────────────

model Project {
  id                String    @id @default(cuid())
  userId            String
  propertyId        String?
  dealId            String?
  name              String
  status            String    @default("intake")
  startDate         DateTime?
  targetCompletion  DateTime?
  budget            Decimal?  @db.Decimal(14, 2)
  actualCost        Decimal?  @db.Decimal(14, 2)
  completionPercent Int       @default(0)
  riskScore         Int       @default(0)
  exitStrategy      String    @default("flip")
  notes             String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks             ProjectTask[]

  @@index([userId])
  @@index([userId, status])
  @@schema("dynasty")
}

model ProjectTask {
  id          String    @id @default(cuid())
  projectId   String
  category    String    @default("general")
  description String
  assignedTo  String?
  dueDate     DateTime?
  status      String    @default("not_started")
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, status])
  @@schema("dynasty")
}

// ─── DISPOSITION ENGINE (LEGACY) ──────────────────────────────────────────────
// Deprecated: superseded by BuyerProfile/BuyerCriteria and DispositionPackage/
// AssignmentPipeline/ClosingTracker below. Kept (not dropped) as the legacy
// backing store for /engines/disposition; see scripts/migrate-legacy-buyer-disposition.ts.

model Buyer {
  id              String    @id @default(cuid())
  userId          String
  name            String
  entity          String?
  email           String?
  phone           String?
  markets         String?
  criteria        String?   @db.Text
  buyerType       String    @default("cash")
  fundingCapacity Decimal?  @db.Decimal(14, 2)
  closeSpeed      Int?
  score           Int       @default(0)
  notes           String?   @db.Text
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dispositions    Disposition[]

  @@index([userId])
  @@index([userId, buyerType])
  @@index([userId, active])
  @@schema("dynasty")
}

model Disposition {
  id            String    @id @default(cuid())
  userId        String
  propertyId    String?
  dealId        String?
  buyerId       String?
  exitStrategy  String    @default("wholesale")
  status        String    @default("marketing")
  listPrice     Decimal?  @db.Decimal(14, 2)
  salePrice     Decimal?  @db.Decimal(14, 2)
  netProfit     Decimal?  @db.Decimal(14, 2)
  daysToExit    Int?
  closeDate     DateTime?
  notes         String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  buyer         Buyer?    @relation(fields: [buyerId], references: [id], onDelete: SetNull)
  deal          Deal?     @relation(fields: [dealId], references: [id], onDelete: SetNull)
  distributions InvestorDistribution[]

  @@index([userId])
  @@index([userId, status])
  @@index([userId, exitStrategy])
  @@schema("dynasty")
}

model InvestorDistribution {
  id            String       @id @default(cuid())
  userId        String
  investorId    String
  dispositionId String?
  amount        Decimal      @db.Decimal(14, 2)
  date          DateTime     @default(now())
  status        String       @default("pending")
  notes         String?      @db.Text
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  investor      Investor     @relation(fields: [investorId], references: [id], onDelete: Cascade)
  disposition   Disposition? @relation(fields: [dispositionId], references: [id], onDelete: SetNull)

  @@index([investorId])
  @@index([dispositionId])
  @@schema("dynasty")
}

// ─── DISPOSITION ENGINE / BUYER CRM ──────────────────────────────────────────

model BuyerProfile {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  name             String
  entity           String?
  email            String?
  phone            String?
  buyerType        String   @default("CASH") @map("buyer_type")
  fundingVerified  Boolean  @default(false) @map("funding_verified")
  fundingCapacity  Decimal? @map("funding_capacity") @db.Decimal(14, 2)
  closeSpeedDays   Int?     @map("close_speed_days")
  dealsClosedCount Int      @default(0) @map("deals_closed_count")
  rating           Int      @default(0)
  status           String   @default("ACTIVE")
  notes            String?  @db.Text
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  criteria         BuyerCriteria[]
  matches          BuyerMatch[]
  assignments      AssignmentPipeline[]

  @@index([userId])
  @@index([userId, status])
  @@index([userId, buyerType])
  @@map("buyer_profiles")
  @@schema("dynasty")
}

model BuyerCriteria {
  id             String   @id @default(cuid())
  buyerProfileId String   @map("buyer_profile_id")
  userId         String   @map("user_id")
  propertyTypes  String[] @default([]) @map("property_types")
  exitStrategies String[] @default([]) @map("exit_strategies")
  markets        String[] @default([])
  minPrice       Decimal? @map("min_price") @db.Decimal(14, 2)
  maxPrice       Decimal? @map("max_price") @db.Decimal(14, 2)
  minArv         Decimal? @map("min_arv") @db.Decimal(14, 2)
  maxCapital     Decimal? @map("max_capital") @db.Decimal(14, 2)
  notes          String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  buyerProfile   BuyerProfile @relation(fields: [buyerProfileId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([buyerProfileId])
  @@index([userId])
  @@map("buyer_criteria")
  @@schema("dynasty")
}

model BuyerMatch {
  id             String   @id @default(cuid())
  dealId         String   @map("deal_id")
  propertyId     String   @map("property_id")
  buyerProfileId String   @map("buyer_profile_id")
  userId         String   @map("user_id")
  matchScore     Int      @map("match_score")
  matchReasons   Json     @default("[]") @map("match_reasons")
  status         String   @default("SUGGESTED")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  deal           Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  property       Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  buyerProfile   BuyerProfile @relation(fields: [buyerProfileId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments    AssignmentPipeline[]

  @@unique([dealId, buyerProfileId])
  @@index([dealId])
  @@index([propertyId])
  @@index([buyerProfileId])
  @@index([userId])
  @@index([userId, status])
  @@index([userId, matchScore])
  @@map("buyer_matches")
  @@schema("dynasty")
}

model DispositionPackage {
  id            String    @id @default(cuid())
  dealId        String    @map("deal_id")
  propertyId    String    @map("property_id")
  userId        String    @map("user_id")
  packageType   String    @default("WHOLESALE_ASSIGNMENT") @map("package_type")
  askingPrice   Decimal?  @map("asking_price") @db.Decimal(14, 2)
  assignmentFee Decimal?  @map("assignment_fee") @db.Decimal(14, 2)
  description   String?   @db.Text
  status        String    @default("DRAFT")
  distributedAt DateTime? @map("distributed_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deal          Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  property      Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments   AssignmentPipeline[]

  @@unique([userId, dealId])
  @@index([dealId])
  @@index([propertyId])
  @@index([userId])
  @@index([userId, status])
  @@map("disposition_packages")
  @@schema("dynasty")
}

model AssignmentPipeline {
  id                   String    @id @default(cuid())
  dealId               String    @map("deal_id")
  packageId            String    @map("package_id")
  buyerProfileId       String    @map("buyer_profile_id")
  buyerMatchId         String?   @map("buyer_match_id")
  userId               String    @map("user_id")
  stage                String    @default("CONTRACT_SENT")
  assignmentFee        Decimal?  @map("assignment_fee") @db.Decimal(14, 2)
  contractDate         DateTime? @map("contract_date")
  dueDiligenceDeadline DateTime? @map("due_diligence_deadline")
  emdReceived          Boolean   @default(false) @map("emd_received")
  notes                String?   @db.Text
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  deal                 Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  package              DispositionPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  buyerProfile         BuyerProfile @relation(fields: [buyerProfileId], references: [id], onDelete: Cascade)
  buyerMatch           BuyerMatch? @relation(fields: [buyerMatchId], references: [id], onDelete: SetNull)
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  closingRecords       ClosingTracker[]

  @@index([dealId])
  @@index([packageId])
  @@index([buyerProfileId])
  @@index([buyerMatchId])
  @@index([userId])
  @@index([userId, stage])
  @@map("assignment_pipeline")
  @@schema("dynasty")
}

model ClosingTracker {
  id                   String    @id @default(cuid())
  dealId               String    @map("deal_id")
  assignmentPipelineId String    @map("assignment_pipeline_id")
  userId               String    @map("user_id")
  closingDate          DateTime? @map("closing_date")
  titleCompany         String?   @map("title_company")
  status               String    @default("SCHEDULED")
  finalAmount          Decimal?  @map("final_amount") @db.Decimal(14, 2)
  fundsReceivedDate    DateTime? @map("funds_received_date")
  notes                String?   @db.Text
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  deal                 Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  assignmentPipeline   AssignmentPipeline @relation(fields: [assignmentPipelineId], references: [id], onDelete: Cascade)
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@index([assignmentPipelineId])
  @@index([userId])
  @@index([userId, status])
  @@map("closing_tracker")
  @@schema("dynasty")
}

// Investment Intelligence Slice 3 ("what changed that I need to pay
// attention to?"). A small, user-facing activity stream - not an audit log,
// not event sourcing. Only records changes that affect an acquisition
// decision (score/decision changes, enrichment completing, a price finally
// being added, a new property arriving via import), not every CRUD write.
model PropertyActivity {
  id         String   @id @default(cuid())
  propertyId String   @map("property_id")
  userId     String   @map("user_id")
  eventType  String   @map("event_type")
  summary    String
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@index([propertyId])
  @@map("property_activity")
  @@schema("dynasty")
}
