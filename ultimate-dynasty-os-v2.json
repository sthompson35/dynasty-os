    {
      "id": "tool-flip-analysis",
      "name": "Tool: Flip Analysis",
      "type": "@n8n/n8n-nodes-langchain.toolHttpRequest",
      "typeVersion": 1.1,
      "position": [
        1180,
        1300
      ],
      "parameters": {
        "toolDescription": "Run a real estate flip deal analysis. Provide purchase_price, repair_budget, and arv (after repair value). Optionally provide closing_costs, holding_costs, selling_costs. Returns total_cost, profit, roi, and GO/NO-GO decision.",
        "method": "POST",
        "url": "={{ $('Dynasty Config').first().json.dynastyApiUrl }}/api/investor/flip-analysis",
        "sendBody": true,
        "specifyBody": "keypair",
        "bodyParameters": {
          "parameters": [
            {
              "name": "purchase_price",
              "value": "={{ $fromAI('purchase_price', 'Purchase price of the property in USD', 'number') }}"
            },
            {
              "name": "repair_budget",
              "value": "={{ $fromAI('repair_budget', 'Repair and renovation budget in USD', 'number') }}"
            },
            {
              "name": "arv",
              "value": "={{ $fromAI('arv', 'After repair value of the property in USD', 'number') }}"
            },
            {
              "name": "closing_costs",
              "value": "={{ $fromAI('closing_costs', 'Closing costs in USD, default 8000', 'number', 8000) }}"
            },
            {
              "name": "holding_costs",
              "value": "={{ $fromAI('holding_costs', 'Holding costs during renovation in USD, default 9000', 'number', 9000) }}"
            },
            {
              "name": "selling_costs",
              "value": "={{ $fromAI('selling_costs', 'Selling costs in USD, default 7000', 'number', 7000) }}"
            }
          ]
        },
        "options": {}
      }
    },
